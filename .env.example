# ════════════════════════════════════════════════════════════
#  telegram-secretary — пример .env
#  Скопировать в .env и заполнить, chmod 600 .env
# ════════════════════════════════════════════════════════════

# ── Telegram ────────────────────────────────────────────────
# Бот с включённым Business Mode (через @BotFather → Bot Settings → Business Mode)
BUSINESS_BOT_TOKEN=123456:your-business-bot-token

# Бот для уведомлений владельцу (control plane)
ONEINT_BOT_TOKEN=123456:your-notify-bot-token

# Telegram ID владельца (число; узнать: @userinfobot)
OWNER_CHAT_ID=123456789

# Случайная строка, передаётся в setWebhook как secret_token
WEBHOOK_SECRET=replace-with-random-string

# ── Сервер ──────────────────────────────────────────────────
PORT=18792
NODE_ENV=production

# Ключ авторизации для админ-API (/api/*): заголовок X-Api-Key.
# Если не задан — /api/* открыт (только для локальной отладки!)
API_KEY=replace-with-random-string

# Каталог стейта (история, pending, персоны, логи)
STATE_DIR=./state

# Каталог персоны секретаря (имя, стиль, красные линии) — см. persona/
#PERSONA_DIR=./persona

# ── Мозг (Brain) ────────────────────────────────────────────
# Драйвер генерации ответов:
#  - stateless-llm — любой OpenAI-совместимый endpoint, память локальная (по умолчанию)
#  - openclaw      — сессии OpenClaw-инстанса per-человек, единая память в workspace
#BRAIN_DRIVER=stateless-llm

# Несколько инстансов и маршрутизация поверхностей — см. instances.example.json
# (скопировать в $STATE_DIR/instances.json или указать путь здесь):
#INSTANCES_FILE=./state/instances.json

# Сколько последних сообщений истории передавать в контекст (stateless-llm)
#HISTORY_CONTEXT_LIMIT=25

# ── LLM endpoint (если INSTANCES_FILE не задан) ─────────────
# Вариант 1 — любой OpenAI-совместимый (приоритетный, если задан):
#  - локальный LiteLLM:   http://localhost:4000
#  - OpenRouter:          https://openrouter.ai/api
#  - кастомный gateway:   https://your-gw.example/api
#LITELLM_BASE_URL=http://localhost:4000
#LITELLM_API_KEY=sk-...

# Модель в формате <provider>/<model>:
#  - openai/gpt-4o
#  - anthropic/claude-sonnet-4-5
#  - openrouter/anthropic/claude-sonnet-4.6
#VIKA_MODEL=openai/gpt-4o

# Вариант 2 — OpenClaw Gateway (используется, если LITELLM_BASE_URL не задан):
#GW_BASE_URL=http://127.0.0.1:18789
#GW_API_KEY=your-openclaw-gateway-token
# VIKA_MODEL по умолчанию: openclaw

# Таймаут запроса к LLM, мс (по умолчанию 45000)
#LLM_TIMEOUT_MS=45000

# ── Control plane (управление из Telegram) ─────────────────
# Long-polling команд и кнопок владельца через бота уведомлений.
# false — выключить (управление только через /api/*)
#CONTROL_POLLING=true

# Задержка ответа в режиме /vacation, сек
#VACATION_DELAY_SECONDS=20

# ── Режимы ──────────────────────────────────────────────────
# DRY_RUN=true — не отправлять в Telegram реально, только логировать
DRY_RUN=false

# DRY_RUN_BRAIN=true — не вызывать LLM, использовать заглушку
# (историческое имя DRY_RUN_VIKA тоже поддерживается)
DRY_RUN_BRAIN=false
