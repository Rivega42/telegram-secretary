# ════════════════════════════════════════════════════════════
#  telegram-secretary — пример .env
#  Скопировать в .env и заполнить, chmod 600 .env
# ════════════════════════════════════════════════════════════

# ── Telegram ────────────────────────────────────────────────
# Бот с включённым Business Mode (через @BotFather → Bot Settings → Business Mode)
BUSINESS_BOT_TOKEN=123456:your-business-bot-token

# Бот для уведомлений владельцу (control plane)
ONEINT_BOT_TOKEN=123456:your-notify-bot-token

# Telegram ID владельца (число; узнать: @userinfobot)
OWNER_CHAT_ID=123456789

# Случайная строка, передаётся в setWebhook как secret_token
WEBHOOK_SECRET=replace-with-random-string

# ── Сервер ──────────────────────────────────────────────────
PORT=18792
NODE_ENV=production

# Ключ авторизации для админ-API (/api/*): заголовок X-Api-Key.
# Если не задан — /api/* открыт (только для локальной отладки!)
API_KEY=replace-with-random-string

# Суперадмин-ключ для /api/admin/* (управление арендаторами, SaaS).
# Не задан — /api/admin/* возвращает 503. Должен отличаться от API_KEY.
#ADMIN_API_KEY=replace-with-strong-random-string

# Публичный базовый URL сервиса (SaaS, онбординг S5): база для авто-setWebhook
# при подключении бота арендатора. Без него вебхук не ставится (канал/секрет
# сохраняются, вебхук настраивается позже). Пример: https://secretary.example.com
#PUBLIC_BASE_URL=https://secretary.example.com

# Ключ шифрования секретов арендаторов at-rest (SaaS): bot-токены и секреты
# вебхуков в tenant_secrets шифруются AES-256-GCM. Любая длинная случайная строка.
# Не задан — секреты хранятся в открытом виде (single-owner/локальная отладка).
# ВАЖНО: смена ключа — через ротацию (ниже), иначе старые секреты не расшифровать.
#SECRETS_KEY=replace-with-long-random-string
# Старые ключи для окна ротации (через запятую). Порядок ротации:
#   1) новый ключ → SECRETS_KEY, прежний → SECRETS_KEYS_OLD, рестарт
#   2) POST /api/admin/secrets/rotate (перешифровка под новый ключ)
#   3) убрать SECRETS_KEYS_OLD, рестарт
#SECRETS_KEYS_OLD=previous-key-1,previous-key-2

# ── Приём оплаты Robokassa (SaaS-биллинг) ───────────────────
# Креды из личного кабинета Robokassa (единый аккаунт на сервис).
# Result URL в настройках Robokassa → https://<домен>/robokassa/result (метод GET или POST)
# Success URL → https://<домен>/robokassa/success ; Fail URL → /robokassa/fail
#ROBOKASSA_MERCHANT_LOGIN=your-shop-login
#ROBOKASSA_PASSWORD1=password-1-for-payment-link
#ROBOKASSA_PASSWORD2=password-2-for-result-signature
#ROBOKASSA_TEST=false            # true/1 — тестовый режим (IsTest=1)
# Цены платных тарифов, ₽/мес (по умолчанию 990 / 4990)
#PRICE_PRO=990
#PRICE_ENTERPRISE=4990

# Каталог стейта (история, pending, персоны, логи)
STATE_DIR=./state

# Каталог персоны секретаря (имя, стиль, красные линии) — см. persona/
#PERSONA_DIR=./persona

# ── Мозг (Brain) ────────────────────────────────────────────
# Драйвер генерации ответов:
#  - stateless-llm — любой OpenAI-совместимый endpoint, память локальная (по умолчанию)
#  - openclaw      — сессии OpenClaw-инстанса per-человек, единая память в workspace
#BRAIN_DRIVER=stateless-llm

# Несколько инстансов и маршрутизация поверхностей — см. instances.example.json
# (скопировать в $STATE_DIR/instances.json или указать путь здесь):
#INSTANCES_FILE=./state/instances.json

# Сколько последних сообщений истории передавать в контекст (stateless-llm)
#HISTORY_CONTEXT_LIMIT=25

# ── LLM endpoint (если INSTANCES_FILE не задан) ─────────────
# Вариант 1 — любой OpenAI-совместимый (приоритетный, если задан):
#  - локальный LiteLLM:   http://localhost:4000
#  - OpenRouter:          https://openrouter.ai/api
#  - кастомный gateway:   https://your-gw.example/api
#LITELLM_BASE_URL=http://localhost:4000
#LITELLM_API_KEY=sk-...

# Модель в формате <provider>/<model>:
#  - openai/gpt-4o
#  - anthropic/claude-sonnet-4-5
#  - openrouter/anthropic/claude-sonnet-4.6
#VIKA_MODEL=openai/gpt-4o

# Вариант 2 — OpenClaw Gateway (используется, если LITELLM_BASE_URL не задан):
#GW_BASE_URL=http://127.0.0.1:18789
#GW_API_KEY=your-openclaw-gateway-token
# VIKA_MODEL по умолчанию: openclaw

# Таймаут запроса к LLM, мс (по умолчанию 45000)
#LLM_TIMEOUT_MS=45000

# Таймаут запросов к Telegram API, мс (по умолчанию 15000)
#TG_TIMEOUT_MS=15000

# Лимит тела HTTP-запроса (webhook'и небольшие; по умолчанию 256kb)
#BODY_LIMIT=256kb

# ── Control plane (управление из Telegram) ─────────────────
# Long-polling команд и кнопок владельца через бота уведомлений.
# false — выключить (управление только через /api/*)
#CONTROL_POLLING=true

# Задержка ответа в режиме /vacation, сек
#VACATION_DELAY_SECONDS=20

# ── Публичные поверхности (комментарии канала, групповой чат) ─
# Бот уведомлений добавляется в discussion-группу канала (privacy mode — off).
# По умолчанию каждый публичный ответ — черновик владельцу на подтверждение.
# true — публиковать сразу без подтверждения (не рекомендуется)
#PUBLIC_AUTO_REPLY=false

# Rate-limit публичных ответов (окно в мс)
#RATELIMIT_PER_USER=3
#RATELIMIT_PER_CHAT=10
#RATELIMIT_WINDOW_MS=600000

# ── Автопостинг канала ──────────────────────────────────────
# ID или @username канала (бот уведомлений — админ канала).
# Пост всегда приходит владельцу черновиком на подтверждение.
#CHANNEL_ID=@my_channel

# Времена генерации постов по МСК, через запятую. Пусто — выключено.
# Темы — в STATE_DIR/content-plan.json; вне расписания: /post [тема]
#POSTING_TIMES=10:00,18:00

# ── Дайджест владельцу ──────────────────────────────────────
# Время ежедневной сводки (МСК, напр. 21:00). Пусто — выключено. Вне расписания: /digest
#DIGEST_TIME=21:00

# ── ВКонтакте (опционально, этап 4) ─────────────────────────
# Личные сообщения сообществу через Callback API (vk.com/<группа> →
# Управление → Работа с API). Автоматизация ЛИЧНОЙ страницы запрещена ВК.
#VK_GROUP_TOKEN=vk1.a....            # токен сообщества (messages)
#VK_CONFIRMATION_CODE=a1b2c3d4       # строка подтверждения из настроек Callback
#VK_SECRET=random-string             # секретный ключ Callback (проверка событий)
# URL для Callback API: https://<домен>/vk/callback

# ── WhatsApp (опционально, этап 4) ──────────────────────────
# Business Cloud API (Meta for Developers → WhatsApp). Диалоги платные.
# Webhook: https://<домен>/wa/webhook (подписка на поле messages)
#WA_TOKEN=EAAG...                    # permanent token приложения
#WA_PHONE_NUMBER_ID=1234567890       # Phone Number ID бизнес-номера
#WA_VERIFY_TOKEN=random-string       # verify token (придумай сам, укажи в Meta)
#WA_APP_SECRET=app-secret            # App Secret — проверка подписи событий

# ── CRM-выгрузка лидов (опционально) ────────────────────────
# Новый лид POST-ится на этот webhook (Make/Zapier/Pipedrive). Пусто — выключено.
#CRM_WEBHOOK_URL=https://hook.make.com/...
#CRM_WEBHOOK_SECRET=bearer-token

# ── Голосовые сообщения (опционально) ───────────────────────
# OpenAI-совместимый endpoint /v1/audio/transcriptions (Whisper):
# OpenAI API, LiteLLM, локальный faster-whisper. Не задан — голосовые
# эскалируются владельцу без транскрипции.
#STT_BASE_URL=https://api.openai.com
#STT_API_KEY=sk-...
#STT_MODEL=whisper-1

# ── Прочее ──────────────────────────────────────────────────
# TTL логов в днях (log-*.jsonl содержат переписки); 0 — не удалять
#LOG_TTL_DAYS=30

# «Печатает…» и отметка прочитанности перед ответом в личке (false — выключить)
#TYPING_SIMULATION=true

# Подмешивать недавние правки владельца как few-shot в промпт (false — выключить)
#FEEDBACK_FEWSHOT=true
#FEEDBACK_FEWSHOT_LIMIT=2

# ── Режимы ──────────────────────────────────────────────────
# DRY_RUN=true — не отправлять в Telegram реально, только логировать
DRY_RUN=false

# DRY_RUN_BRAIN=true — не вызывать LLM, использовать заглушку
# (историческое имя DRY_RUN_VIKA тоже поддерживается)
DRY_RUN_BRAIN=false
