# ════════════════════════════════════════════════════════════
#  GH-Secretary — пример .env
#  Скопировать в .env и заполнить, chmod 600 .env
# ════════════════════════════════════════════════════════════

# ── Telegram ────────────────────────────────────────────────
# Бот с включённым Business Mode (через @BotFather → Bot Settings)
BUSINESS_BOT_TOKEN=your_b…here

# Бот для уведомлений владельцу (control plane)
ONEINT_BOT_TOKEN=your_o…here

# Telegram ID владельца (число)
OWNER_CHAT_ID=357896330

# Случайная строка, передаётся в setWebhook?secret_token=
WEBHOOK_SECRET=please…here

# ── Сервер ──────────────────────────────────────────────────
PORT=18792
NODE_ENV=production

# Каталог стейта (connections, contacts, pending, logs)
STATE_DIR=./state

# ── LLM (Vika ответы) ───────────────────────────────────────
# Адрес OpenAI-совместимого endpoint:
#  - локальный LiteLLM:   http://localhost:4000
#  - OpenRouter:          https://openrouter.ai/api
#  - кастомный gateway:   https://your-gw.example/api
LITELLM_BASE_URL=http://localhost:4000

# API ключ для LITELLM_BASE_URL
LITELLM_API_KEY=sk-l…here

# Модель в формате <provider>/<model>
#  - openai/gpt-4o
#  - anthropic/claude-sonnet-4-5
#  - openrouter/anthropic/claude-3.5-sonnet
VIKA_MODEL=openai/gpt-4o

# ── Режимы ─────────────────────────────────────────────────
# DRY_RUN=true — не отправлять реально, только логировать
DRY_RUN=false

# DRY_RUN_VIKA=true — не вызывать LLM, использовать заглушку
DRY_RUN_VIKA=false
GW_API_KEY=токен_OpenClaw_gateway
